<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item >
        <shape android:shape="rectangle">
            <solid android:color="#91EEEEEE"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <item android:top="-4dp" android:left="-4dp" android:right="-4dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#05AEA8"/>
            <corners android:radius="7dp"/>
        </shape>
    </item>
</layer-list>