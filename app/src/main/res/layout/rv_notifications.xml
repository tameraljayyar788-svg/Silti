<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="20dp"
    android:background="@drawable/notifications_background"
    android:layout_margin="15dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/notifications_background">
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="عنوان الاشعار"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_margin="15dp"
            android:textSize="18sp"/>
        <TextView
            android:id="@+id/massage"
            android:layout_width="270dp"
            android:layout_height="30dp"
            app:layout_constraintTop_toBottomOf="@id/title"
            app:layout_constraintRight_toRightOf="@id/title"
            android:textSize="15sp"
            android:textColor="#7F7F7F"
            android:text="كيف يمكنني مساعدتك اليوم؟"
            android:paddingBottom="5dp"
            android:layout_marginTop="5dp"/>
        <ImageView
            android:id="@+id/imageNotification"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:layout_constraintTop_toTopOf="@id/title"
            app:layout_constraintBottom_toTopOf="@id/massage"
            android:src="@drawable/robot"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginLeft="20dp"/>

        <TextView
            android:id="@+id/time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/massage"
            app:layout_constraintTop_toBottomOf="@id/imageNotification"
            android:textColor="#7F7F7F"
            android:text="10:30 am"
            app:layout_constraintLeft_toLeftOf="@id/imageNotification"
            app:layout_constraintRight_toRightOf="@id/imageNotification"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.cardview.widget.CardView>



