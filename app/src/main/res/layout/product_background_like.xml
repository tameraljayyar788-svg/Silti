<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="165dp"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="10dp"
    app:cardCornerRadius="20dp"
    android:background="@drawable/backgorund_product"
    android:padding="5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/backgorund_product">

        <!-- صورة المنتج -->
        <ImageView
            android:id="@+id/ImgProduct"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logo"
            app:layout_constraintTop_toBottomOf="@id/like_product"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <!-- اسم المنتج -->
        <TextView
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/ImgProduct"
            android:layout_marginTop="8dp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="اسم المنتج"/>

        <!-- السعر -->
        <TextView
            android:id="@+id/price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/name"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="4dp"
            android:layout_marginStart="12dp"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="$100"/>

        <!-- رمز العملة -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/price"
            app:layout_constraintBottom_toBottomOf="@id/price"
            app:layout_constraintRight_toRightOf="@id/price"
            android:layout_marginEnd="2dp"/>

        <!-- زر الإعجاب (أحمر للإزالة) -->
        <ImageButton
            android:id="@+id/like_product"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/like_red"
            android:padding="6dp"
            android:background="@drawable/background_like"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="4dp"
            android:layout_marginRight="4dp"/>

        <!-- زر إضافة إلى السلة -->
        <ImageButton
            android:id="@+id/addToCart"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/cart"
            android:padding="6dp"
            android:background="@drawable/background_like"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginBottom="4dp"
            android:layout_marginRight="4dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>