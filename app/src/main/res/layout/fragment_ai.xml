<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Ai"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- صورة الروبوت الرئيسية -->
        <ImageView
            android:id="@+id/img"
            android:layout_width="153dp"
            android:layout_height="120dp"
            android:src="@drawable/robot"
            android:scaleType="fitCenter"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="40dp"
            android:clickable="true"
            android:focusable="true"/>

        <!-- عنوان المساعد الذكي -->
        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/img"
            app:layout_constraintStart_toStartOf="@id/img"
            app:layout_constraintEnd_toEndOf="@id/img"
            android:textSize="25sp"
            android:layout_marginTop="15dp"
            android:textColor="@color/black"
            android:text="المساعد الذكي"
            android:fontFamily="@font/tajwal"
            android:textStyle="bold"/>

        <!-- نص المساعدة -->
        <TextView
            android:id="@+id/textHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/text"
            app:layout_constraintStart_toStartOf="@id/img"
            app:layout_constraintEnd_toEndOf="@id/img"
            android:textSize="16sp"
            android:layout_marginTop="5dp"
            android:textColor="#757575"
            android:text="أخبرني كيف يمكنني مساعدتك"
            android:fontFamily="@font/tajwal"/>

        <!-- RecyclerView للمحادثة -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChat"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:paddingHorizontal="12dp"
            android:clipToPadding="false"
            android:visibility="gone"
            android:background="@android:color/transparent"
            app:layout_constraintTop_toBottomOf="@id/textHint"
            app:layout_constraintBottom_toTopOf="@id/chatInputLayout"/>

        <!-- حاوية حقل الإدخال والأزرار -->
        <LinearLayout
            android:id="@+id/chatInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@color/white"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- حقل إدخال النص -->
            <EditText
                android:id="@+id/chat"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:hint="اكتب رسالتك..."
                android:paddingStart="16dp"
                android:paddingEnd="8dp"
                android:background="@drawable/search_background"
                android:textColor="@color/black"
                android:textColorHint="#7D7D7D"
                android:textSize="14sp"
                android:maxLines="3"/>

            <!-- زر الإضافة (إرفاق) -->
            <ImageView
                android:id="@+id/add"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/add"
                android:background="@drawable/add_back"
                android:padding="10dp"
                android:layout_marginStart="8dp"
                android:visibility="gone"/>

            <!-- زر الإرسال -->
            <ImageView
                android:id="@+id/send"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/send_back"
                android:background="@drawable/send"
                android:padding="10dp"
                android:layout_marginStart="8dp"/>


        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>