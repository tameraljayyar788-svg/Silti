<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Ai"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">
        <ImageView
            android:id="@+id/img"
            android:layout_width="153dp"
            android:layout_height="120dp"
            android:src="@drawable/robot"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="40dp"/>
        <TextView
            android:id="@+id/text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/img"
            app:layout_constraintStart_toStartOf="@id/img"
            app:layout_constraintEnd_toEndOf="@id/img"
            android:textSize="25sp"
            android:layout_marginTop="15dp"
            android:textColor="@color/black"
            android:text=" المساعد الذكي"/>
        <TextView
            android:id="@+id/textHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/text"
            app:layout_constraintStart_toStartOf="@id/img"
            app:layout_constraintEnd_toEndOf="@id/img"
            android:textSize="18sp"
            android:layout_marginTop="5dp"
            android:textColor="#929292"
            android:text="أخبرني كيف يمكنني مساعدتك" />

        <EditText
            android:id="@+id/chat"
            android:layout_width="250dp"
            android:layout_height="45dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:hint="عن ماذا تبحث لكي أساعدك؟"
            android:paddingRight="10dp"
            android:background="@drawable/search_background"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="10dp"/>

        <ImageView
            android:id="@+id/add"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/add"
            android:background="@drawable/add_back"
           app:layout_constraintTop_toTopOf="@id/chat"
            android:padding="12dp"
            app:layout_constraintBottom_toBottomOf="@id/chat"
            app:layout_constraintRight_toLeftOf="@id/chat"
            android:layout_marginRight="5dp"
            />

        <ImageView
        android:id="@+id/send"
        android:layout_width="40dp"
        android:layout_height="40dp"
            android:padding="10dp"
        android:src="@drawable/send_back"
            android:background="@drawable/send"
            app:layout_constraintTop_toTopOf="@id/add"
            app:layout_constraintEnd_toStartOf="@id/add"
            android:layout_marginEnd="5dp"
       />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>