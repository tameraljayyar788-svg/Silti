<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".HomeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- ========== Header ========== -->
        <TextView
            android:id="@+id/nameApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#0DC893"
            android:fontFamily="@font/bold"
            android:textSize="20dp"
            android:text="سلتي"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginRight="15sp"
            android:layout_marginTop="15sp"/>

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/logo"
            android:layout_marginRight="5dp"
            app:layout_constraintRight_toLeftOf="@id/nameApp"
            app:layout_constraintTop_toTopOf="@id/nameApp"
            app:layout_constraintBottom_toBottomOf="@id/nameApp"/>

        <ImageView
            android:id="@+id/notification"
            android:layout_width="23dp"
            android:layout_height="23dp"
            android:src="@drawable/notification"
            android:layout_marginLeft="15sp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="@id/nameApp"
            app:layout_constraintBottom_toBottomOf="@id/nameApp"/>

        <!-- ========== NestedScrollView للمحتوى ========== -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toBottomOf="@id/nameApp"
            android:layout_marginTop="60dp"
            android:scrollbarStyle="insideInset"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- ========== شريط البحث ========== -->
                <TextView
                    android:id="@+id/search"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:hint="بحث على منتجات"
                    android:drawableRight="@drawable/search"
                    android:drawablePadding="8dp"
                    android:textColorHint="#7D7D7D"
                    android:padding="10dp"
                    android:background="@drawable/search_background"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- ==========المنتجات التي عليها خصومات ========== -->
                <ImageButton
                    android:id="@+id/offersMain"
                    android:layout_width="340dp"
                    android:layout_height="197dp"
                    android:background="@drawable/back_offers"
                    app:layout_constraintTop_toBottomOf="@id/search"
                    android:src="@drawable/newoffer"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginStart="20dp"/>

                <!-- ========== التصنيفات الرئيسية ========== -->

                <!-- تصنيف: بيت -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/home"
                    android:layout_width="105dp"
                    android:layout_height="90dp"
                    android:background="@drawable/category3"
                    app:layout_constraintTop_toBottomOf="@id/offersMain"
                    app:layout_constraintRight_toRightOf="@id/offersMain"
                    android:layout_marginTop="10dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/icon3"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:backgroundTint="#72A599"
                        app:cardCornerRadius="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15sp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/home_icon"
                            android:layout_gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/text3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textColor="@color/white"
                        android:text="بيت"
                        android:textSize="18sp"
                        app:layout_constraintTop_toBottomOf="@id/icon3"
                        android:layout_marginTop="5dp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- تصنيف: الجمال -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/prety"
                    android:layout_width="105dp"
                    android:layout_height="90dp"
                    android:background="@drawable/category1"
                    app:layout_constraintTop_toTopOf="@id/home"
                    app:layout_constraintLeft_toLeftOf="@id/offersMain">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/icon1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:backgroundTint="#6CECD3"
                        app:cardCornerRadius="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15sp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/makeup"
                            android:layout_gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/text1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/icon1"
                        android:layout_marginTop="5dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textColor="@color/white"
                        android:text="الجمال"
                        android:textSize="18sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- تصنيف: موضة -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/fation"
                    android:layout_width="105dp"
                    app:layout_constraintTop_toTopOf="@id/prety"
                    app:layout_constraintRight_toRightOf="@id/home"
                    app:layout_constraintLeft_toLeftOf="@id/prety"
                    android:layout_height="90dp"
                    android:background="@drawable/category2">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/icon2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:backgroundTint="#83E29B"
                        app:cardCornerRadius="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15sp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/clothes"
                            android:layout_gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/text2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/icon2"
                        android:layout_marginTop="5dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textColor="@color/white"
                        android:text="موضة"
                        android:textSize="18sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- تصنيف: إلكترونيات -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="105dp"
                    android:id="@+id/elictronic"
                    app:layout_constraintTop_toBottomOf="@id/prety"
                    app:layout_constraintRight_toRightOf="@id/home"
                    android:layout_height="90dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/category4">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/icon4"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:backgroundTint="#80C395"
                        app:cardCornerRadius="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15sp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/elictroimc"
                            android:layout_gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/text4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/icon4"
                        app:layout_constraintEnd_toEndOf="parent"
                        android:layout_marginTop="5dp"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textColor="@color/white"
                        android:text="إلكترونيات"
                        android:textSize="18sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- تصنيف: كُتب -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/books"
                    android:layout_width="105dp"
                    app:layout_constraintTop_toTopOf="@id/elictronic"
                    app:layout_constraintRight_toRightOf="@id/fation"
                    app:layout_constraintLeft_toLeftOf="@id/fation"
                    android:layout_height="90dp"
                    android:background="@drawable/category5">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/icon5"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:backgroundTint="#50C6C2"
                        app:cardCornerRadius="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15sp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/book"
                            android:layout_gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/text5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/icon5"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="5dp"
                        android:textColor="@color/white"
                        android:text="كُتب"
                        android:textSize="18sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- تصنيف: رياضة -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/sport"
                    android:layout_width="105dp"
                    android:layout_height="90dp"
                    app:layout_constraintTop_toTopOf="@id/books"
                    app:layout_constraintLeft_toLeftOf="@id/prety"
                    android:background="@drawable/category6">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/icon6"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:backgroundTint="#5DD8B9"
                        app:cardCornerRadius="10dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:layout_marginTop="15sp">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/sport"
                            android:layout_gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/text6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintTop_toBottomOf="@id/icon6"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        android:textColor="@color/white"
                        android:layout_marginTop="5dp"
                        android:text="رياضة"
                        android:textSize="18sp"/>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- ========== عنوان الأكثر مبيعاً ========== -->


                <!-- ========== قسم عروض اليوم ========== -->


                <!-- ========== قسم قد يعجبك أيضاً ========== -->
                <TextView
                    android:id="@+id/recommendedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/sport"
                    app:layout_constraintRight_toRightOf="@id/offersMain"
                    android:textSize="19sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="25dp"
                    android:text="قد يعجبك أيضاً"/>

                <HorizontalScrollView
                    android:id="@+id/recommendedScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/white"
                    app:layout_constraintTop_toBottomOf="@id/recommendedTitle"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:id="@+id/recommendedContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="5dp"
                        android:layout_marginRight="10dp"
                        android:background="@color/white">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvRecommended"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            android:nestedScrollingEnabled="false"/>
                    </LinearLayout>
                </HorizontalScrollView>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>