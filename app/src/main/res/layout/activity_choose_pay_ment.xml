<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ChoosePayMent"
    android:background="@color/white">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="20dp"
        android:text="إختر طريقة الدفع"
        android:fontFamily="@font/tajwal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginRight="15sp"/>

    <ImageButton
        android:id="@+id/back"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@color/white"
        android:src="@drawable/close"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="15dp"/>

    <View
        android:id="@+id/line1"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        android:layout_marginTop="10dp"
        android:background="#9E9D9D"/>

    <!-- بطاقة إضافة بطاقة -->
    <androidx.cardview.widget.CardView
        android:id="@+id/add"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@+id/line1"
        app:cardCornerRadius="15dp"
        app:cardElevation="4dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/linear_card"
            android:padding="12dp">

            <TextView
                android:id="@+id/text"
                android:layout_width="wrap_content"
                android:layout_height="45dp"
                android:layout_marginRight="10dp"
                android:gravity="center"
                android:text="إضافة بطاقة"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <ImageView
                android:id="@+id/view"
                android:layout_width="18sp"
                android:layout_height="18sp"
                android:layout_marginLeft="15dp"
                android:src="@drawable/more_white"
                app:layout_constraintBottom_toBottomOf="@id/text"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="@id/text"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- حقل إضافة بطاقة -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dataCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/add"
        android:layout_margin="15dp"
        android:background="@drawable/linear_card"
        android:padding="12dp">

        <EditText
            android:id="@+id/number_card"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:textSize="18sp"
            android:background="@drawable/edit_border"
            android:layout_margin="8dp"
            android:paddingStart="12dp"
            app:layout_constraintTop_toTopOf="parent"
            android:hint="رقم البطاقة"
            android:inputType="number"/>

        <EditText
            android:id="@+id/name_card"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/edit_border"
            android:layout_margin="8dp"
            android:paddingStart="12dp"
            app:layout_constraintTop_toBottomOf="@id/number_card"
            android:hint="اسم البطاقة"
            android:inputType="text"/>

        <TextView
            android:id="@+id/text_remember"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/name_card"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:text="حفظ بيانات البطاقة"
            app:layout_constraintRight_toRightOf="parent"/>

        <Switch
            android:id="@+id/saveCard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/text_remember"
            app:layout_constraintLeft_toLeftOf="parent"
            android:thumbTint="#05AEA8"
            android:trackTint="#FFFFFF"
            android:checked="false"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ✅ إضافة ID للـ ConstraintLayout الخاص بالدفع كاش -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cashLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/search_background"
        app:layout_constraintTop_toBottomOf="@id/dataCard"
        android:layout_marginTop="10dp"
        android:layout_margin="15sp"
        android:padding="12dp">

        <TextView
            android:id="@+id/text_cash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_margin="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="الدفع كاش عند التوصيل"/>

        <Switch
            android:id="@+id/cash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_margin="15sp"
            android:checked="false"
            android:trackTint="#05AEA8"
            android:thumbTint="#04897F"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/agree"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:background="@drawable/button_login"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cashLayout"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:textSize="18sp"
        android:text="تأكيد"
        android:textColor="@color/white"/>

</androidx.constraintlayout.widget.ConstraintLayout>