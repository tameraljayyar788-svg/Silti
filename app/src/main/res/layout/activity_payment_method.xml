<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PaymentMethod"
    android:background="@color/white">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="25dp"
        android:text="طريقة الدفع"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:fontFamily="@font/tajwal"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center"
        android:layout_marginTop="20dp"/>

    <ImageButton
        android:id="@+id/back"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:background="@color/white"
        android:src="@drawable/back"
        app:layout_constraintTop_toTopOf="@id/title"
        app:layout_constraintBottom_toBottomOf="@id/title"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="15dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/location"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/title"
        android:layout_margin="15dp"
        android:background="@drawable/payment1">

        <TextView
            android:id="@+id/textLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9E9D9D"
            android:text="الموقع"
            android:textSize="17dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginTop="7dp"
            android:layout_marginRight="10dp"/>

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/textLocation"
            app:layout_constraintBottom_toBottomOf="@id/textLocation"
            android:src="@drawable/location"
            app:layout_constraintRight_toLeftOf="@id/textLocation"
            android:layout_marginRight="5dp"/>

        <TextView
            android:id="@+id/nameCountry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            app:layout_constraintTop_toBottomOf="@id/textLocation"
            app:layout_constraintRight_toRightOf="@id/textLocation"
            android:text="الدولة"/>

        <Spinner
            android:id="@+id/spinerCountry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginLeft="10dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/paymentMethode"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/location"
        android:layout_margin="15dp"
        android:background="@drawable/payment1">

      <TextView
          android:id="@+id/textPayment"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:textColor="@color/black"
          android:textSize="18sp"
          android:text="اختر طريقة الدفع"
          app:layout_constraintRight_toRightOf="parent"
          android:layout_marginRight="10dp"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintTop_toTopOf="parent"
          />

        <ImageView
            android:id="@+id/hands"
            android:layout_width="18dp"
            android:layout_height="20dp"
            android:src="@drawable/payment"
            app:layout_constraintRight_toLeftOf="@id/textPayment"
            app:layout_constraintTop_toTopOf="@id/textPayment"
            app:layout_constraintBottom_toBottomOf="@id/textPayment"
            android:layout_marginRight="5dp"
            />

        <ImageView
            android:id="@+id/openPagePayment"
            android:layout_width="18dp"
            android:layout_height="20dp"
            android:src="@drawable/back"
            app:layout_constraintLeft_toLeftOf="parent"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="@id/textPayment"
            app:layout_constraintBottom_toBottomOf="@id/textPayment"
            android:layout_marginLeft="10dp"
            />


    </androidx.constraintlayout.widget.ConstraintLayout>

    <EditText
        android:id="@+id/firstName"
        android:layout_width="match_parent"
        android:hint="* الاسم الاول"
        android:layout_height="45dp"
        android:background="@drawable/payment1"
        android:textSize="18sp"
        android:textColorHint="#9E9D9D"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/paymentMethode"/>
    <EditText
        android:id="@+id/lastName"
        android:layout_width="match_parent"
        android:hint="* الاسم الاخير"
        android:layout_height="45dp"
        android:textColorHint="#9E9D9D"
        android:background="@drawable/payment1"
        android:textSize="18sp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/firstName"/>
    <EditText
        android:id="@+id/phone"
        android:layout_width="match_parent"
        android:hint="*  رقم الهاتف"
        android:textColorHint="#9E9D9D"
        android:layout_height="45dp"
        android:background="@drawable/payment1"
        android:textSize="18sp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/lastName"/>
    <EditText
        android:id="@+id/email"
        android:layout_width="match_parent"
        android:hint="*  البريد الالكتروني"
        android:textColorHint="#9E9D9D"
        android:layout_height="45dp"
        android:background="@drawable/payment1"
        android:textSize="18sp"
        android:layout_margin="15dp"
        android:inputType="textEmailAddress"
        app:layout_constraintTop_toBottomOf="@id/phone"/>
    <EditText
        android:id="@+id/city"
        android:layout_width="match_parent"
        android:hint="*  المدينة"
        android:layout_height="45dp"
        android:background="@drawable/payment1"
        android:textColorHint="#9E9D9D"
        android:textSize="18sp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/email"/>
    <EditText
        android:id="@+id/location1"
        android:layout_width="match_parent"
        android:hint="* العنوان الاول"
        android:layout_height="45dp"
        android:textColorHint="#9E9D9D"
        android:background="@drawable/payment1"
        android:textSize="18sp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/city"/>
    <EditText
        android:id="@+id/location2"
        android:layout_width="match_parent"
        android:hint="* العنوان الثاني"
        android:layout_height="45dp"
        android:textColorHint="#9E9D9D"
        android:background="@drawable/payment1"
        android:textSize="18sp"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/location1"/>


    <Button
        android:id="@+id/agree"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:background="@drawable/button_login"
        app:layout_constraintTop_toBottomOf="@id/location2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:text="تأكيد"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>