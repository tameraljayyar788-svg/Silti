<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainProduct"
    android:background="@color/white">

    <ImageView
        android:id="@+id/back"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/back"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="15dp"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginRight="15dp"
        />
    <ImageView
        android:id="@+id/cart"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/black_cart"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="15dp"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="15dp"
        />

    <ImageView
        android:id="@+id/img_product"
        android:layout_width="250dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toBottomOf="@id/back"
        android:background="@drawable/more_sell1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"/>

    <View
        android:id="@+id/line"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        app:layout_constraintTop_toBottomOf="@id/img_product"
        android:background="@color/black"
        android:layout_margin="15dp"/>

    <TextView
        android:id="@+id/name_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/line"
        android:layout_marginTop="15dp"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:text="اسم المنتج"
        android:layout_marginRight="15dp"
        />


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dataProduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        app:layout_constraintTop_toBottomOf="@id/name_product"
        />






    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_pice_mainproduct"
        app:layout_constraintBottom_toBottomOf="parent"
        android:padding="10dp"
        >


        <TextView
            android:id="@+id/textPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:text="السعر"
            android:layout_marginRight="5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <TextView
            android:id="@+id/oldPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="120"
            app:layout_constraintTop_toTopOf="@id/textPrice"
            android:textColor="#838383"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginLeft="20sp"
            android:textSize="16sp"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10dp"
            android:textColor="@color/black"
            android:text="$"
            app:layout_constraintTop_toTopOf="@id/oldPrice"
            app:layout_constraintRight_toRightOf="@id/oldPrice"
            android:layout_marginRight="30dp"
            android:textStyle="italic|bold"/>

        <com.google.android.material.internal.BaselineLayout
            android:layout_width="30dp"
            android:layout_height="1dp"
            app:layout_constraintTop_toTopOf="@id/oldPrice"
            app:layout_constraintBottom_toBottomOf="@id/oldPrice"
            android:background="@color/black"
            app:layout_constraintStart_toStartOf="@id/oldPrice"/>
        <TextView
            android:id="@+id/newPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="100"
            app:layout_constraintTop_toTopOf="@id/textPrice"
            android:textColor="#00CB14"
            app:layout_constraintLeft_toRightOf="@id/oldPrice"
            android:layout_marginLeft="20sp"
            android:textSize="16sp"
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10dp"
            android:textColor="@color/black"
            android:text="$"
            app:layout_constraintTop_toTopOf="@id/newPrice"
            app:layout_constraintRight_toRightOf="@id/newPrice"
            android:layout_marginRight="30dp"
            android:textStyle="italic|bold"/>


        <Button
            android:id="@+id/button_sell"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:text="شراء الأن"
            android:textColor="@color/white"
            android:background="@drawable/button_login"
            app:layout_constraintRight_toRightOf="@id/textPrice"
            app:layout_constraintTop_toBottomOf="@id/textPrice"
            android:layout_marginTop="10dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="5dp"
            app:layout_constraintLeft_toLeftOf="@id/oldPrice"
            app:layout_constraintTop_toTopOf="@id/button_sell"
            app:layout_constraintBottom_toBottomOf="@id/button_sell"
            >
            <Button
                android:id="@+id/minus"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/background_like"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:layout_margin="5dp"
                android:text="-"
                />

            <TextView
                android:id="@+id/quantity"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/background_like"
                android:layout_margin="5dp"
                android:text="1"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:layout_gravity="center"
                android:gravity="center"/>
            <Button
                android:id="@+id/plus"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:background="@drawable/background_like"
                android:textColor="@color/black"
                android:layout_margin="5dp"
                android:textSize="18sp"
                android:text="+"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>